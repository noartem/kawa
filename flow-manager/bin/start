#!/usr/bin/env bash
set -euo pipefail

PATH="/usr/bin:/bin:${PATH:-}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
PID_FILE="$RUN_DIR/flow-manager.pid"
LOG_FILE="${FLOW_MANAGER_LOG_FILE:-$RUN_DIR/flow-manager.log}"
HOST="${FLOW_MANAGER_HOST:-0.0.0.0}"
PORT="${FLOW_MANAGER_PORT:-8000}"
UVICORN_BIN="$ROOT_DIR/.venv/bin/uvicorn"

is_pid_active() {
    local pid="$1"
    local state=""

    if [[ -z "$pid" ]] || ! kill -0 "$pid" 2>/dev/null; then
        return 1
    fi

    if [[ ! -r "/proc/$pid/stat" ]]; then
        return 1
    fi

    IFS=' ' read -r _ _ state _ < "/proc/$pid/stat" || return 1

    if [[ -z "$state" ]] || [[ "$state" == "Z" ]]; then
        return 1
    fi

    return 0
}

find_running_pid() {
    local arg=""
    local cmdline=""
    local proc_dir=""
    local proc_pid=""
    local line=""
    local pid=""

    for proc_dir in /proc/[0-9]*; do
        proc_pid="${proc_dir#/proc/}"

        if ! is_pid_active "$proc_pid" || [[ ! -r "$proc_dir/cmdline" ]]; then
            continue
        fi

        cmdline=""
        while IFS= read -r -d '' arg; do
            if [[ -n "$cmdline" ]]; then
                cmdline+=" "
            fi
            cmdline+="$arg"
        done < "$proc_dir/cmdline"

        if [[ "$cmdline" == *"uvicorn main:app --host $HOST --port $PORT"* ]]; then
            pid="$proc_pid"
        fi
    done

    if [[ -n "$pid" ]] && is_pid_active "$pid"; then
        printf '%s' "$pid"
    fi
}

mkdir -p "$RUN_DIR"

if [[ -f "$PID_FILE" ]]; then
    existing_pid="$(<"$PID_FILE")"
    if is_pid_active "$existing_pid"; then
        printf 'Flow Manager is already running (pid %s).\n' "$existing_pid"
        printf 'Log file: %s\n' "$LOG_FILE"
        exit 0
    fi

    rm -f "$PID_FILE"
fi

existing_pid="$(find_running_pid)"
if [[ -n "$existing_pid" ]]; then
    printf '%s\n' "$existing_pid" >"$PID_FILE"
    printf 'Flow Manager is already running (pid %s).\n' "$existing_pid"
    printf 'Log file: %s\n' "$LOG_FILE"
    exit 0
fi

if [[ -x "$UVICORN_BIN" ]]; then
    server_cmd=("$UVICORN_BIN")
elif command -v uv >/dev/null 2>&1; then
    server_cmd=(uv run uvicorn)
else
    printf 'Neither %s nor uv is available to start Flow Manager.\n' "$UVICORN_BIN" >&2
    exit 1
fi

cd "$ROOT_DIR"
nohup setsid "${server_cmd[@]}" main:app --host "$HOST" --port "$PORT" >>"$LOG_FILE" 2>&1 &

sleep 1

pid="$(find_running_pid)"
if [[ -n "$pid" ]]; then
    printf '%s\n' "$pid" >"$PID_FILE"
    printf 'Flow Manager started (pid %s) on %s:%s.\n' "$pid" "$HOST" "$PORT"
    printf 'Log file: %s\n' "$LOG_FILE"
    exit 0
fi

rm -f "$PID_FILE"
printf 'Failed to start Flow Manager. Check log file: %s\n' "$LOG_FILE" >&2
exit 1
