#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
PID_FILE="$RUN_DIR/flow-manager.pid"
LOG_FILE="${FLOW_MANAGER_LOG_FILE:-$RUN_DIR/flow-manager.log}"
HOST="${FLOW_MANAGER_HOST:-0.0.0.0}"
PORT="${FLOW_MANAGER_PORT:-8000}"

is_pid_active() {
    local pid="$1"
    local state=""

    if [[ -z "$pid" ]] || ! kill -0 "$pid" 2>/dev/null; then
        return 1
    fi

    state="$(ps -o stat= -p "$pid" 2>/dev/null || true)"
    state="${state//[[:space:]]/}"

    if [[ -z "$state" ]] || [[ "${state:0:1}" == "Z" ]]; then
        return 1
    fi

    return 0
}

mkdir -p "$RUN_DIR"

if [[ -f "$PID_FILE" ]]; then
    existing_pid="$(<"$PID_FILE")"
    if is_pid_active "$existing_pid"; then
        printf 'Flow Manager is already running (pid %s).\n' "$existing_pid"
        printf 'Log file: %s\n' "$LOG_FILE"
        exit 0
    fi

    rm -f "$PID_FILE"
fi

if ! command -v uv >/dev/null 2>&1; then
    printf 'uv is not installed. Install it first: https://docs.astral.sh/uv/\n' >&2
    exit 1
fi

cd "$ROOT_DIR"
nohup setsid uv run uvicorn main:app --host "$HOST" --port "$PORT" >>"$LOG_FILE" 2>&1 &
pid=$!
printf '%s\n' "$pid" >"$PID_FILE"

sleep 1

if is_pid_active "$pid"; then
    printf 'Flow Manager started (pid %s) on %s:%s.\n' "$pid" "$HOST" "$PORT"
    printf 'Log file: %s\n' "$LOG_FILE"
    exit 0
fi

rm -f "$PID_FILE"
printf 'Failed to start Flow Manager. Check log file: %s\n' "$LOG_FILE" >&2
exit 1
