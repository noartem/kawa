#!/usr/bin/env bash
set -euo pipefail

PATH="/usr/bin:/bin:${PATH:-}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
PID_FILE="$RUN_DIR/flow-manager.pid"
HOST="${FLOW_MANAGER_HOST:-0.0.0.0}"
PORT="${FLOW_MANAGER_PORT:-8000}"

is_pid_active() {
    local pid="$1"
    local state=""

    if [[ -z "$pid" ]] || ! kill -0 "$pid" 2>/dev/null; then
        return 1
    fi

    if [[ ! -r "/proc/$pid/stat" ]]; then
        return 1
    fi

    IFS=' ' read -r _ _ state _ < "/proc/$pid/stat" || return 1

    if [[ -z "$state" ]] || [[ "$state" == "Z" ]]; then
        return 1
    fi

    return 0
}

find_running_pid() {
    local arg=""
    local cmdline=""
    local proc_dir=""
    local proc_pid=""
    local line=""
    local pid=""

    for proc_dir in /proc/[0-9]*; do
        proc_pid="${proc_dir#/proc/}"

        if ! is_pid_active "$proc_pid" || [[ ! -r "$proc_dir/cmdline" ]]; then
            continue
        fi

        cmdline=""
        while IFS= read -r -d '' arg; do
            if [[ -n "$cmdline" ]]; then
                cmdline+=" "
            fi
            cmdline+="$arg"
        done < "$proc_dir/cmdline"

        if [[ "$cmdline" == *"uvicorn main:app --host $HOST --port $PORT"* ]]; then
            pid="$proc_pid"
        fi
    done

    if [[ -n "$pid" ]] && is_pid_active "$pid"; then
        printf '%s' "$pid"
    fi
}

get_process_group() {
    local pid="$1"
    local pgid=""

    if [[ -r "/proc/$pid/stat" ]]; then
        IFS=' ' read -r _ _ _ _ pgid _ < "/proc/$pid/stat" || true
    fi

    printf '%s' "$pgid"
}

if [[ ! -f "$PID_FILE" ]]; then
    pid="$(find_running_pid)"
    if [[ -z "$pid" ]]; then
        printf 'Flow Manager is not running (pid file not found).\n'
        exit 0
    fi
    printf '%s\n' "$pid" >"$PID_FILE"
fi

pid="$(<"$PID_FILE")"

if [[ -z "$pid" ]]; then
    rm -f "$PID_FILE"
    printf 'Removed invalid pid file.\n'
    exit 0
fi

if ! is_pid_active "$pid"; then
    stale_pid="$pid"
    pid="$(find_running_pid)"
    if [[ -z "$pid" ]]; then
        rm -f "$PID_FILE"
        printf 'Flow Manager is not running (stale pid %s).\n' "$stale_pid"
        exit 0
    fi
    printf '%s\n' "$pid" >"$PID_FILE"
fi

pgid="$(get_process_group "$pid")"
current_pgid="$(get_process_group "$$")"

if [[ -n "$pgid" ]] && [[ "$pgid" != "$current_pgid" ]]; then
    kill -TERM -- "-$pgid" 2>/dev/null || kill "$pid"
else
    kill "$pid"
fi

for _ in {1..20}; do
    if ! is_pid_active "$pid"; then
        rm -f "$PID_FILE"
        printf 'Flow Manager stopped (pid %s).\n' "$pid"
        exit 0
    fi
    sleep 0.5
done

if [[ -n "$pgid" ]] && [[ "$pgid" != "$current_pgid" ]]; then
    kill -KILL -- "-$pgid" 2>/dev/null || kill -9 "$pid" 2>/dev/null || true
else
    kill -9 "$pid" 2>/dev/null || true
fi
sleep 0.2

if is_pid_active "$pid"; then
    printf 'Failed to stop Flow Manager (pid %s).\n' "$pid" >&2
    exit 1
fi

rm -f "$PID_FILE"
printf 'Flow Manager force-stopped (pid %s).\n' "$pid"
