#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.ui-dev-common.sh"

mkdir -p "$RUN_DIR"

stopped_any=false

if [[ -f "$PID_FILE" ]]; then
    pid="$(<"$PID_FILE")"

    if [[ -n "$pid" ]] && is_pid_active "$pid"; then
        stopped_any=true
        signal_pid_or_group TERM "$pid"

        if ! wait_for_pid_exit "$pid" 20; then
            signal_pid_or_group KILL "$pid"
            sleep 0.2
        fi

        if is_pid_active "$pid"; then
            printf 'Failed to stop UI dev stack (pid %s).\n' "$pid" >&2
            exit 1
        fi
    fi
fi

if tracked_ports_in_use; then
    stopped_any=true
fi

terminate_tracked_ports
remove_runtime_files

if [[ "$stopped_any" == true ]]; then
    printf 'UI dev stack stopped.\n'
    exit 0
fi

printf 'UI dev stack is not running.\n'
