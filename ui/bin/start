#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.ui-dev-common.sh"

resolve_port() {
    local key="$1"
    local fallback="$2"
    local port=""

    port="$(configured_port "$key" || true)"

    if [[ -n "$port" ]]; then
        printf '%s\n' "$port"
        return 0
    fi

    printf '%s\n' "$fallback"
}

mkdir -p "$RUN_DIR"

if [[ -f "$PID_FILE" ]]; then
    existing_pid="$(<"$PID_FILE")"
    if is_pid_active "$existing_pid"; then
        printf 'UI dev stack is already running (pid %s).\n' "$existing_pid"
        printf 'Log file: %s\n' "$LOG_FILE"
        exit 0
    fi

    rm -f "$PID_FILE"
fi

if ! command -v composer >/dev/null 2>&1; then
    printf 'composer is not installed or not in PATH.\n' >&2
    exit 1
fi

export APP_PORT="$(resolve_port APP_PORT 9000)"
export VITE_PORT="$(resolve_port VITE_PORT 5173)"
export VITE_HMR_CLIENT_PORT="$(resolve_port VITE_HMR_CLIENT_PORT "$VITE_PORT")"

terminate_port_listener 'APP_PORT' "$APP_PORT"
terminate_port_listener 'VITE_PORT' "$VITE_PORT"

if [[ "$VITE_HMR_CLIENT_PORT" != "$VITE_PORT" ]]; then
    terminate_port_listener 'VITE_HMR_CLIENT_PORT' "$VITE_HMR_CLIENT_PORT"
fi

write_runtime_ports "$APP_PORT" "$VITE_PORT" "$VITE_HMR_CLIENT_PORT"

cd "$ROOT_DIR"
nohup setsid composer run dev >>"$LOG_FILE" 2>&1 &
pid=$!
printf '%s\n' "$pid" >"$PID_FILE"

sleep 1

if is_pid_active "$pid"; then
    printf 'UI dev stack started (pid %s).\n' "$pid"
    printf 'Log file: %s\n' "$LOG_FILE"
    exit 0
fi

remove_runtime_files
printf 'Failed to start UI dev stack. Check log file: %s\n' "$LOG_FILE" >&2
exit 1
